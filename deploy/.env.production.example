# Copie para o SERVIDOR como .env no mesmo directório de docker-stack.yml
# (ex.: /root/vera-trajes-deploy/.env) e ajuste os valores.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=6etiiPPzOuiwg
POSTGRES_DB=verastore

# Obrigatório. A partir do container API, "localhost" no host NÃO é o PostgreSQL
# do host; use o IP/hostname de rede acessível ao Swarm, ou o nome do serviço postgres.
DATABASE_URL="postgresql://postgres:6etiiPPzOuiwg@postgres:5432/verastore?schema=public"

PORT=4000
NODE_ENV=production

# Secret forte; não reutilize valores de desenvolvimento.
JWT_SECRET="hq4VAjmBg5XG58lU7JkJeLo2033"
JWT_EXPIRES_IN="7d"

# Inclua o domínio HTTPS público e origens adicionais separadas por vírgula, sem espaços extra.
CORS_ORIGIN="https://vera-store.cetara.dev.br"

# Deve bater com o que os utilizadores abrem no browser (HTTPS).
PUBLIC_BASE_URL="https://vera-store.cetara.dev.br"

# Upload local (volume da stack) ou "cloudinary"
UPLOAD_MODE="local"
UPLOAD_LOCAL_DIR="uploads"

# Produção com login: false
AUTH_DISABLED=false
CRON_ENABLED=true

# Opcional: Cloudinary, WhatsApp — ver backend/.env.example
