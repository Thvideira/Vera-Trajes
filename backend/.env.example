# Cole este arquivo como .env na pasta backend (comando: cp .env.example .env)

# Se você usar `docker compose up -d` na RAIZ do projeto, use exatamente esta URL:
DATABASE_URL="postgresql://lojavera:lojavera_dev@localhost:5432/loja_vera?schema=public"

# Se o PostgreSQL for outro (usuário/senha/porta), ajuste só esta linha.

PORT=4000
# Opcional. Padrão 0.0.0.0 (API acessível na rede local para testar no iPhone).
# LISTEN_HOST=127.0.0.1
JWT_SECRET="troque-em-producao"
JWT_EXPIRES_IN="7d"
# Para testar no celular pelo IP do Mac, inclua a origem do Vite, ex.:
# CORS_ORIGIN="http://localhost:5173,http://192.168.0.10:5173"
CORS_ORIGIN="http://localhost:5173"

# Upload: "local" ou "cloudinary"
UPLOAD_MODE="local"
# URLs de fotos: no iPhone use o IP da máquina, não localhost, ex.:
# PUBLIC_BASE_URL="http://192.168.0.10:4000"
PUBLIC_BASE_URL="http://localhost:4000"
UPLOAD_LOCAL_DIR="uploads"

# Cloudinary (se UPLOAD_MODE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER="loja-vera"

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION="v21.0"

# Cron diário de notificações
CRON_ENABLED=true

# Desenvolvimento: true = API sem JWT
AUTH_DISABLED=true
